# Environment variables for TOPFORM LINE Bot
# Copy this to .env and fill in the values

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
ADMIN_USER_ID=

# Google Calendar API (JSON or base64 encoded)
GOOGLE_CREDENTIALS_JSON=

# 石原早見表 URL (existing Vercel deployment)
HAYAMIHYO_URL=https://ishihara-booking.vercel.app

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database
DATABASE_PATH=./topform_line.db
